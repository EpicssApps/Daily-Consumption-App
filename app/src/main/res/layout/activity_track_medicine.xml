<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Medicine"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Vehicle Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Vehicle"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spTrackVehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- Indent Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Indent Number"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTrackIndent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter indent number"
            android:inputType="number" />

        <!-- Search Button -->
        <Button
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Search" />

        <!-- Result Info -->
        <TextView
            android:id="@+id/tvResultInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textStyle="bold"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Results List -->
        <TextView
            android:id="@+id/tvResultList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1Fffffff"
            android:padding="12dp"
            android:text="No results."
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:minHeight="150dp"
            android:gravity="top|start"
            android:visibility="gone" />

        <!-- Share PDF Button -->
        <Button
            android:id="@+id/btnSharePdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Share as PDF (WhatsApp)"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

